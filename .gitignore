wandb/
.wandb/
wandb-*.log

# claude-mem / agent tool context dumps (auto-emitted)
AGENTS.md

# Stray copies of files already under data/ — root-level duplicates
/Deep_Learning_EDA_ipynb_adlı_not_defterinin_kopyası.ipynb
/SENG474_Presentation_Team3.pptx

# brainstorm visual companion
.superpowers/

# secrets (.env already listed above)
frontend/.env.local
# tmdb runtime cache (gitignored, regenerable)
artifacts/cache/tmdb/

# teammate artifact bundle outputs (scripts/package-artifacts.sh) — too large for git
cineembed-artifacts-*.tar.gz

